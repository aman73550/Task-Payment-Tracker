{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "resourceClass": "default"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "node": "18.13.0"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "resourceClass": "default"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "node": "18.13.0"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "resourceClass": "default"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "node": "18.13.0"
    }
  },
  "submit": {
    "production": {}
  }
}
